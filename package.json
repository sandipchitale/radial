{
  "name": "radial",
  "version": "0.0.1",
  "description": "Transparent concentric radial menu built with Electron, Vite, and Tailwind CSS",
  "main": "dist-electron/radial.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist-linux": "vite build && electron-builder --linux --x64",
    "dist-mac": "vite build && electron-builder --mac",
    "dist-win": "vite build && electron-builder --win"
  },
  "author": "Sandip Chitale (https://www.linkedin.com/in/sandipchitale/)",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.sandipchitale.radial",
    "productName": "Radial",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "icons/**/*",
      "package.json"
    ],
    "asar": true,
    "publish": null,
    "linux": {
      "icon": "icons/radial512x512.png",
      "target": ["AppImage"],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "icons/radial512x512.png"
    },
    "mac": {
      "icon": "icons/radial512x512.png"
    }
  }
}
